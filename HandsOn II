import java.util.Scanner;

public class HandsOnII {
    
    public static void main(String[] args) {
        Scanner leitor = new Scanner(System.in);
        int opcao = -1;

        while (opcao != 0) {
            System.out.println("\n--- MENU DE EXERCÍCIOS - HandsON II ---");
            System.out.println("1. Exercício 01");
            System.out.println("2. Exercício 02");
            System.out.println("3. Exercício 03");
            System.out.println("4. Exercício 04");
            System.out.println("0. Sair");
            System.out.print("Escolha uma opção: ");

            opcao = leitor.nextInt();

            switch (opcao) {
                case 1:
                    executarExercicio01();
                    break;
                case 2:
                    executarExercicio02();
                    break;
                case 3:
                    executarExercicio03();
                    break;
                case 4:
                    executarExercicio04();
                    break;
                case 0:
